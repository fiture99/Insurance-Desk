# Copy this file to .env at the project root and fill in your local values.
# This is only needed when running the project OUTSIDE Replit (e.g. on your laptop).
# Inside Replit, PORT/BASE_PATH/DATABASE_URL are already provided automatically.

# Postgres connection string for lib/db (used by the api-server and drizzle-kit push)
DATABASE_URL=postgresql://localhost:5432/insurance_desk

# Port for the api-server (artifacts/api-server)
PORT=5000

# Port + base path for the mockup-sandbox dev server (artifacts/mockup-sandbox)
# Note: Vite only loads .env files from its own package root, so if you want
# these to apply to the mockup-sandbox automatically, copy this file to
# artifacts/mockup-sandbox/.env.local instead, or just pass them inline:
#   PORT=5173 BASE_PATH=/ pnpm --filter @workspace/mockup-sandbox run dev
